<?xml version = "1.0" encoding = "UTF-8" ?>
<Application xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:EmpleadosApp"
             xmlns:converters="clr-namespace:EmpleadosApp.Converters"
             x:Class="EmpleadosApp.App">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Resources/Styles/Colors.xaml" />
                <ResourceDictionary Source="Resources/Styles/Styles.xaml" />
                <ResourceDictionary Source="Resources/Styles/AppStyles.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <converters:StringNotEmptyConverter x:Key="StringNotEmpty" />
            <converters:IsNotNullConverter x:Key="IsNotNull" />
            <converters:InicialConverter x:Key="Inicial" />
            <converters:DoubleToStarConverter x:Key="Star" />
            <converters:InvertedBoolConverter x:Key="Invertir" />
        </ResourceDictionary>
    </Application.Resources>
</Application>
