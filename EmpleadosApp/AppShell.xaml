<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="EmpleadosApp.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:views="clr-namespace:EmpleadosApp.Views"
    Title="EmpleadosApp"
    FlyoutBehavior="Flyout">

    <ShellContent Title="Login"
                  ContentTemplate="{DataTemplate views:LoginPage}"
                  Route="login" />

    <ShellContent Title="Inicio"
                  ContentTemplate="{DataTemplate views:PrincipalPage}"
                  Route="principal" />

    <ShellContent Title="Empleados"
                  ContentTemplate="{DataTemplate views:EmpleadosListPage}"
                  Route="empleados" />

    <ShellContent Title="Formulario"
                  ContentTemplate="{DataTemplate views:EmpleadoFormPage}"
                  Route="empleado-form" />

</Shell>
