<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:models="clr-namespace:EmpleadosApp.Models"
             x:Class="EmpleadosApp.Views.CargosListPage"
             BackgroundColor="{StaticResource SurfaceBackground}"
             Title="Cargos">

    <Grid Padding="20,16,20,20" RowDefinitions="Auto,*,Auto" RowSpacing="14">

        <VerticalStackLayout Grid.Row="0" Spacing="2">
            <Label Text="Cargos"
                   Style="{StaticResource HeaderLabel}" />
            <Label Text="Toca un cargo para editarlo"
                   Style="{StaticResource SubheaderLabel}" />
        </VerticalStackLayout>

        <Border Grid.Row="1" Style="{StaticResource Card}" Padding="0">
            <CollectionView x:Name="CargosCollection"
                            SelectionMode="Single"
                            SelectionChanged="OnCargoSeleccionado">
                <CollectionView.EmptyView>
                    <VerticalStackLayout Padding="24,48" Spacing="6" HorizontalOptions="Center" VerticalOptions="Center">
                        <Label Text="Sin cargos"
                               FontSize="17"
                               FontAttributes="Bold"
                               TextColor="{StaticResource Gray900}"
                               HorizontalOptions="Center" />
                        <Label Text="Crea el primero con el botón de abajo."
                               Style="{StaticResource SubheaderLabel}"
                               HorizontalOptions="Center" />
                    </VerticalStackLayout>
                </CollectionView.EmptyView>
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="models:Cargo">
                        <VerticalStackLayout Spacing="0">
                            <Grid Padding="20,14" ColumnDefinitions="*,Auto,Auto" ColumnSpacing="12">
                                <VerticalStackLayout Grid.Column="0" Spacing="2" VerticalOptions="Center">
                                    <Label Text="{Binding Nombre}" Style="{StaticResource RowTitle}" />
                                    <Label Text="{Binding SalarioBase, StringFormat='Salario base: ${0:N2}'}"
                                           Style="{StaticResource RowSubtitle}" />
                                </VerticalStackLayout>
                                <Border Grid.Column="1" Style="{StaticResource Pill}">
                                    <Label Text="{Binding Estado}" Style="{StaticResource PillText}" />
                                </Border>
                                <Label Grid.Column="2" Style="{StaticResource Chevron}" />
                            </Grid>
                            <BoxView Style="{StaticResource Divider}" />
                        </VerticalStackLayout>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </Border>

        <Button Grid.Row="2"
                Text="+ Nuevo cargo"
                Style="{StaticResource PrimaryButton}"
                Clicked="OnNuevoCargoClicked" />

    </Grid>

</ContentPage>
