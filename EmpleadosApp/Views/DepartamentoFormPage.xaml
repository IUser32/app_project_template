<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:EmpleadosApp.ViewModels"
             x:DataType="vm:DepartamentoFormViewModel"
             x:Class="EmpleadosApp.Views.DepartamentoFormPage"
             BackgroundColor="{StaticResource SurfaceBackground}"
             Title="{Binding TituloPagina}">

    <Grid RowDefinitions="*,Auto">

        <ScrollView Grid.Row="0">
            <VerticalStackLayout Padding="20,16,20,8" Spacing="2">

                <Label Text="DATOS DEL DEPARTAMENTO" Style="{StaticResource SectionLabel}" />

                <Label Text="Nombre" Style="{StaticResource FormLabel}" />
                <Border Style="{StaticResource Field}">
                    <Entry Text="{Binding Nombre}" Style="{StaticResource FieldInput}" Placeholder="Ej. Sistemas" />
                </Border>
                <Label Text="{Binding NombreError}"
                       Style="{StaticResource ErrorLabel}"
                       IsVisible="{Binding NombreError, Converter={StaticResource StringNotEmpty}}" />

                <Label Text="Descripción" Style="{StaticResource FormLabel}" />
                <Border Style="{StaticResource Field}">
                    <Editor Text="{Binding Descripcion}"
                            BackgroundColor="Transparent"
                            TextColor="{StaticResource Gray900}"
                            PlaceholderColor="{StaticResource Gray400}"
                            Placeholder="Breve descripción del departamento"
                            AutoSize="TextChanges"
                            HeightRequest="100" />
                </Border>
                <Label Text="{Binding DescripcionError}"
                       Style="{StaticResource ErrorLabel}"
                       IsVisible="{Binding DescripcionError, Converter={StaticResource StringNotEmpty}}" />

                <Label Text="Estado" Style="{StaticResource FormLabel}" />
                <Border Style="{StaticResource Field}">
                    <Picker ItemsSource="{Binding EstadosDisponibles}"
                            SelectedItem="{Binding EstadoSeleccionado}"
                            Style="{StaticResource FieldPicker}"
                            Title="Selecciona un estado" />
                </Border>
                <Label Text="{Binding EstadoError}"
                       Style="{StaticResource ErrorLabel}"
                       IsVisible="{Binding EstadoError, Converter={StaticResource StringNotEmpty}}" />

            </VerticalStackLayout>
        </ScrollView>

        <VerticalStackLayout Grid.Row="1" Spacing="10" Margin="20,8,20,16">
            <Button Text="Guardar departamento"
                    Style="{StaticResource PrimaryButton}"
                    Command="{Binding GuardarCommand}" />
            <Button Text="Eliminar departamento"
                    Style="{StaticResource DangerButton}"
                    Command="{Binding EliminarCommand}"
                    IsVisible="{Binding ModoEditar}" />
        </VerticalStackLayout>

    </Grid>

</ContentPage>
