<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:models="clr-namespace:EmpleadosApp.Models"
             x:Class="EmpleadosApp.Views.DepartamentosListPage"
             BackgroundColor="{StaticResource SurfaceBackground}"
             Title="Departamentos">

    <Grid Padding="16" RowDefinitions="Auto,*,Auto" RowSpacing="12">

        <VerticalStackLayout Grid.Row="0" Spacing="2">
            <Label Text="Departamentos"
                   Style="{StaticResource HeaderLabel}" />
            <Label Text="Toca un departamento para editarlo"
                   Style="{StaticResource SubheaderLabel}" />
        </VerticalStackLayout>

        <Border Grid.Row="1" Style="{StaticResource Card}" Padding="0">
            <CollectionView x:Name="DepartamentosCollection"
                            SelectionMode="Single"
                            SelectionChanged="OnDepartamentoSeleccionado">
                <CollectionView.EmptyView>
                    <VerticalStackLayout Padding="24" Spacing="6" HorizontalOptions="Center" VerticalOptions="Center">
                        <Label Text="Sin departamentos"
                               FontSize="16"
                               FontAttributes="Bold"
                               HorizontalOptions="Center" />
                        <Label Text="Crea el primero con el botón de abajo."
                               Style="{StaticResource SubheaderLabel}"
                               HorizontalOptions="Center" />
                    </VerticalStackLayout>
                </CollectionView.EmptyView>
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="models:Departamento">
                        <Grid Padding="16,12" ColumnDefinitions="*,Auto" ColumnSpacing="12">
                            <VerticalStackLayout Grid.Column="0" Spacing="2">
                                <Label Text="{Binding Nombre}"
                                       FontAttributes="Bold"
                                       FontSize="15" />
                                <Label Text="{Binding Descripcion}"
                                       FontSize="13"
                                       TextColor="{StaticResource Gray500}"
                                       LineBreakMode="TailTruncation"
                                       MaxLines="2" />
                            </VerticalStackLayout>

                            <Label Grid.Column="1"
                                   Text="{Binding Estado}"
                                   FontSize="12"
                                   FontAttributes="Bold"
                                   TextColor="{StaticResource Primary}"
                                   VerticalOptions="Center" />
                        </Grid>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </Border>

        <Button Grid.Row="2"
                Text="+ Nuevo departamento"
                Style="{StaticResource PrimaryButton}"
                Clicked="OnNuevoDepartamentoClicked" />

    </Grid>

</ContentPage>
