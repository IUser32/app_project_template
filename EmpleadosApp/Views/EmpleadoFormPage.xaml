<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:EmpleadosApp.ViewModels"
             x:DataType="vm:EmpleadoFormViewModel"
             x:Class="EmpleadosApp.Views.EmpleadoFormPage"
             BackgroundColor="{StaticResource SurfaceBackground}"
             Title="{Binding TituloPagina}">

    <Grid RowDefinitions="*,Auto">

        <ScrollView Grid.Row="0">
            <VerticalStackLayout Padding="20,16,20,8" Spacing="2">

                <Label Text="DATOS PERSONALES" Style="{StaticResource SectionLabel}" />

                <Label Text="Nombre" Style="{StaticResource FormLabel}" />
                <Border Style="{StaticResource Field}">
                    <Entry Text="{Binding Nombre}" Style="{StaticResource FieldInput}" Placeholder="Ej. Juan" />
                </Border>
                <Label Text="{Binding NombreError}"
                       Style="{StaticResource ErrorLabel}"
                       IsVisible="{Binding NombreError, Converter={StaticResource StringNotEmpty}}" />

                <Label Text="Apellido" Style="{StaticResource FormLabel}" />
                <Border Style="{StaticResource Field}">
                    <Entry Text="{Binding Apellido}" Style="{StaticResource FieldInput}" Placeholder="Ej. Pérez" />
                </Border>
                <Label Text="{Binding ApellidoError}"
                       Style="{StaticResource ErrorLabel}"
                       IsVisible="{Binding ApellidoError, Converter={StaticResource StringNotEmpty}}" />

                <Label Text="Cédula" Style="{StaticResource FormLabel}" />
                <Border Style="{StaticResource Field}">
                    <Entry Text="{Binding Cedula}"
                           Style="{StaticResource FieldInput}"
                           Placeholder="10 dígitos"
                           Keyboard="Numeric"
                           MaxLength="10" />
                </Border>
                <Label Text="{Binding CedulaError}"
                       Style="{StaticResource ErrorLabel}"
                       IsVisible="{Binding CedulaError, Converter={StaticResource StringNotEmpty}}" />

                <Label Text="Fecha de nacimiento" Style="{StaticResource FormLabel}" />
                <Border Style="{StaticResource Field}">
                    <DatePicker Date="{Binding FechaNacimiento}" Style="{StaticResource FieldDatePicker}" Format="dd/MM/yyyy" />
                </Border>
                <Label Text="{Binding FechaNacimientoError}"
                       Style="{StaticResource ErrorLabel}"
                       IsVisible="{Binding FechaNacimientoError, Converter={StaticResource StringNotEmpty}}" />

                <Label Text="Teléfono" Style="{StaticResource FormLabel}" />
                <Border Style="{StaticResource Field}">
                    <Entry Text="{Binding Telefono}"
                           Style="{StaticResource FieldInput}"
                           Placeholder="10 dígitos"
                           Keyboard="Telephone"
                           MaxLength="10" />
                </Border>
                <Label Text="{Binding TelefonoError}"
                       Style="{StaticResource ErrorLabel}"
                       IsVisible="{Binding TelefonoError, Converter={StaticResource StringNotEmpty}}" />

                <Label Text="Correo" Style="{StaticResource FormLabel}" />
                <Border Style="{StaticResource Field}">
                    <Entry Text="{Binding Correo}"
                           Style="{StaticResource FieldInput}"
                           Placeholder="ejemplo@correo.com"
                           Keyboard="Email" />
                </Border>
                <Label Text="{Binding CorreoError}"
                       Style="{StaticResource ErrorLabel}"
                       IsVisible="{Binding CorreoError, Converter={StaticResource StringNotEmpty}}" />

                <Label Text="INFORMACIÓN LABORAL" Style="{StaticResource SectionLabel}" />

                <Label Text="Departamento" Style="{StaticResource FormLabel}" />
                <Border Style="{StaticResource Field}">
                    <Picker ItemsSource="{Binding DepartamentosDisponibles}"
                            ItemDisplayBinding="{Binding Nombre}"
                            SelectedItem="{Binding DepartamentoSeleccionado}"
                            Style="{StaticResource FieldPicker}"
                            Title="Selecciona un departamento" />
                </Border>
                <Label Text="{Binding DepartamentoError}"
                       Style="{StaticResource ErrorLabel}"
                       IsVisible="{Binding DepartamentoError, Converter={StaticResource StringNotEmpty}}" />

                <Label Text="Cargo" Style="{StaticResource FormLabel}" />
                <Border Style="{StaticResource Field}">
                    <Picker ItemsSource="{Binding CargosDisponibles}"
                            ItemDisplayBinding="{Binding Nombre}"
                            SelectedItem="{Binding CargoSeleccionado}"
                            Style="{StaticResource FieldPicker}"
                            Title="Selecciona un cargo"
                            IsEnabled="{Binding DepartamentoSeleccionado, Converter={StaticResource IsNotNull}}" />
                </Border>
                <Label Text="{Binding CargoError}"
                       Style="{StaticResource ErrorLabel}"
                       IsVisible="{Binding CargoError, Converter={StaticResource StringNotEmpty}}" />

                <Label Text="Fecha de ingreso" Style="{StaticResource FormLabel}" />
                <Border Style="{StaticResource Field}">
                    <DatePicker Date="{Binding FechaIngreso}" Style="{StaticResource FieldDatePicker}" Format="dd/MM/yyyy" />
                </Border>
                <Label Text="{Binding FechaIngresoError}"
                       Style="{StaticResource ErrorLabel}"
                       IsVisible="{Binding FechaIngresoError, Converter={StaticResource StringNotEmpty}}" />

                <Label Text="Salario" Style="{StaticResource FormLabel}" />
                <Border Style="{StaticResource Field}">
                    <Entry Text="{Binding SalarioTexto}"
                           Style="{StaticResource FieldInput}"
                           Placeholder="0.00"
                           Keyboard="Numeric" />
                </Border>
                <Label Text="{Binding SalarioError}"
                       Style="{StaticResource ErrorLabel}"
                       IsVisible="{Binding SalarioError, Converter={StaticResource StringNotEmpty}}" />

                <Label Text="Estado" Style="{StaticResource FormLabel}" />
                <Border Style="{StaticResource Field}">
                    <Picker ItemsSource="{Binding EstadosDisponibles}"
                            SelectedItem="{Binding EstadoSeleccionado}"
                            Style="{StaticResource FieldPicker}"
                            Title="Selecciona un estado" />
                </Border>
                <Label Text="{Binding EstadoError}"
                       Style="{StaticResource ErrorLabel}"
                       IsVisible="{Binding EstadoError, Converter={StaticResource StringNotEmpty}}" />

            </VerticalStackLayout>
        </ScrollView>

        <VerticalStackLayout Grid.Row="1" Spacing="10" Margin="20,8,20,16">
            <Button Text="Guardar empleado"
                    Style="{StaticResource PrimaryButton}"
                    Command="{Binding GuardarCommand}" />
            <Button Text="Eliminar empleado"
                    Style="{StaticResource DangerButton}"
                    Command="{Binding EliminarCommand}"
                    IsVisible="{Binding ModoEditar}" />
        </VerticalStackLayout>

    </Grid>

</ContentPage>
