<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:models="clr-namespace:EmpleadosApp.Models"
             x:Class="EmpleadosApp.Views.EmpleadosListPage"
             BackgroundColor="{StaticResource SurfaceBackground}"
             Title="Empleados">

    <Grid Padding="16" RowDefinitions="Auto,Auto,*,Auto" RowSpacing="12">

        <VerticalStackLayout Grid.Row="0" Spacing="2">
            <Label Text="Empleados registrados"
                   Style="{StaticResource HeaderLabel}" />
            <Label Text="Toca un empleado para editarlo"
                   Style="{StaticResource SubheaderLabel}" />
        </VerticalStackLayout>

        <SearchBar Grid.Row="1"
                   x:Name="BuscarBar"
                   Placeholder="Buscar por nombre, cédula o cargo"
                   TextChanged="OnBuscarTextChanged" />

        <Border Grid.Row="2" Style="{StaticResource Card}" Padding="0">
            <CollectionView x:Name="EmpleadosCollection"
                            SelectionMode="Single"
                            SelectionChanged="OnEmpleadoSeleccionado">
                <CollectionView.EmptyView>
                    <VerticalStackLayout Padding="24" Spacing="6" HorizontalOptions="Center" VerticalOptions="Center">
                        <Label Text="Sin resultados"
                               FontSize="16"
                               FontAttributes="Bold"
                               HorizontalOptions="Center" />
                        <Label Text="Ajusta la búsqueda o agrega un nuevo empleado."
                               Style="{StaticResource SubheaderLabel}"
                               HorizontalOptions="Center" />
                    </VerticalStackLayout>
                </CollectionView.EmptyView>
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="models:Empleado">
                        <Grid Padding="16,12" ColumnDefinitions="*,Auto" ColumnSpacing="12">
                            <VerticalStackLayout Grid.Column="0" Spacing="2">
                                <Label Text="{Binding NombreCompleto}"
                                       FontAttributes="Bold"
                                       FontSize="15" />
                                <Label Text="{Binding CargoNombre}"
                                       FontSize="13"
                                       TextColor="{StaticResource Gray500}" />
                                <Label Text="{Binding DepartamentoNombre}"
                                       FontSize="12"
                                       TextColor="{StaticResource Gray400}" />
                            </VerticalStackLayout>

                            <VerticalStackLayout Grid.Column="1"
                                                 Spacing="6"
                                                 VerticalOptions="Center">
                                <Label Text="{Binding Estado}"
                                       FontSize="12"
                                       FontAttributes="Bold"
                                       TextColor="{StaticResource Primary}"
                                       HorizontalOptions="End" />
                                <Button Text="Eliminar"
                                        BackgroundColor="{StaticResource Danger}"
                                        TextColor="White"
                                        FontSize="11"
                                        HeightRequest="32"
                                        WidthRequest="80"
                                        CornerRadius="6"
                                        Padding="0"
                                        Clicked="OnEliminarEmpleadoClicked" />
                            </VerticalStackLayout>
                        </Grid>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </Border>

        <Button Grid.Row="3"
                Text="+ Nuevo empleado"
                Style="{StaticResource PrimaryButton}"
                Clicked="OnNuevoEmpleadoClicked" />

    </Grid>

</ContentPage>
