<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:models="clr-namespace:EmpleadosApp.Models"
             x:Class="EmpleadosApp.Views.EmpleadosListPage"
             BackgroundColor="{StaticResource SurfaceBackground}"
             Title="Empleados">

    <Grid Padding="20,16,20,20" RowDefinitions="Auto,Auto,*,Auto" RowSpacing="14">

        <VerticalStackLayout Grid.Row="0" Spacing="2">
            <Label Text="Empleados"
                   Style="{StaticResource HeaderLabel}" />
            <Label Text="Toca un empleado para editarlo"
                   Style="{StaticResource SubheaderLabel}" />
        </VerticalStackLayout>

        <Border Grid.Row="1" Style="{StaticResource Field}" Padding="6,0">
            <SearchBar x:Name="BuscarBar"
                       Placeholder="Buscar por nombre, cédula o cargo"
                       BackgroundColor="Transparent"
                       TextColor="{StaticResource Gray900}"
                       PlaceholderColor="{StaticResource Gray400}"
                       CancelButtonColor="{StaticResource Primary}"
                       TextChanged="OnBuscarTextChanged" />
        </Border>

        <Border Grid.Row="2" Style="{StaticResource Card}" Padding="0">
            <CollectionView x:Name="EmpleadosCollection"
                            SelectionMode="Single"
                            SelectionChanged="OnEmpleadoSeleccionado">
                <CollectionView.EmptyView>
                    <VerticalStackLayout Padding="24,48" Spacing="6" HorizontalOptions="Center" VerticalOptions="Center">
                        <Label Text="Sin resultados"
                               FontSize="17"
                               FontAttributes="Bold"
                               TextColor="{StaticResource Gray900}"
                               HorizontalOptions="Center" />
                        <Label Text="Ajusta la búsqueda o agrega un nuevo empleado."
                               Style="{StaticResource SubheaderLabel}"
                               HorizontalOptions="Center" />
                    </VerticalStackLayout>
                </CollectionView.EmptyView>
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="models:Empleado">
                        <VerticalStackLayout Spacing="0">
                            <Grid Padding="20,14" ColumnDefinitions="Auto,*,Auto,Auto" ColumnSpacing="14">

                                <Border Grid.Column="0"
                                        WidthRequest="44" HeightRequest="44"
                                        BackgroundColor="{StaticResource PrimaryLight}"
                                        VerticalOptions="Center">
                                    <Border.StrokeShape>
                                        <RoundRectangle CornerRadius="22" />
                                    </Border.StrokeShape>
                                    <Label Text="{Binding Nombre, Converter={StaticResource Inicial}}"
                                           TextColor="{StaticResource Primary}"
                                           FontSize="17"
                                           FontAttributes="Bold"
                                           HorizontalOptions="Center"
                                           VerticalOptions="Center" />
                                </Border>

                                <VerticalStackLayout Grid.Column="1" Spacing="2" VerticalOptions="Center">
                                    <Label Text="{Binding NombreCompleto}" Style="{StaticResource RowTitle}" />
                                    <Label Text="{Binding CargoNombre}" Style="{StaticResource RowSubtitle}" />
                                    <Label Text="{Binding DepartamentoNombre}"
                                           FontSize="12.5"
                                           TextColor="{StaticResource Gray400}" />
                                </VerticalStackLayout>

                                <Border Grid.Column="2" Style="{StaticResource Pill}">
                                    <Label Text="{Binding Estado}" Style="{StaticResource PillText}" />
                                </Border>

                                <Label Grid.Column="3" Style="{StaticResource Chevron}" />
                            </Grid>
                            <BoxView Style="{StaticResource Divider}" />
                        </VerticalStackLayout>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </Border>

        <Button Grid.Row="3"
                Text="+ Nuevo empleado"
                Style="{StaticResource PrimaryButton}"
                Clicked="OnNuevoEmpleadoClicked" />

    </Grid>

</ContentPage>
