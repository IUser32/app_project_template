<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="EmpleadosApp.Views.LoginPage"
             BackgroundColor="{StaticResource SurfaceBackground}"
             Title="Iniciar sesión">

    <ScrollView>
        <Grid Padding="28" RowDefinitions="*,Auto,*">

            <VerticalStackLayout Grid.Row="1" Spacing="28" VerticalOptions="Center">

                <VerticalStackLayout Spacing="10" HorizontalOptions="Center">
                    <Border WidthRequest="64"
                            HeightRequest="64"
                            BackgroundColor="{StaticResource Primary}"
                            HorizontalOptions="Center">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="20" />
                        </Border.StrokeShape>
                        <Label Text="E"
                               TextColor="White"
                               FontSize="32"
                               FontAttributes="Bold"
                               HorizontalOptions="Center"
                               VerticalOptions="Center" />
                    </Border>

                    <Label Text="Gestión de Empleados"
                           FontSize="24"
                           FontAttributes="Bold"
                           TextColor="{StaticResource Gray900}"
                           HorizontalOptions="Center" />
                    <Label Text="Inicia sesión para continuar"
                           Style="{StaticResource SubheaderLabel}"
                           HorizontalOptions="Center" />
                </VerticalStackLayout>

                <Border Style="{StaticResource Card}">
                    <VerticalStackLayout Spacing="4">

                        <Label Text="Usuario" Style="{StaticResource FormLabel}" />
                        <Border Style="{StaticResource Field}">
                            <Entry x:Name="UsuarioEntry"
                                   Style="{StaticResource FieldInput}"
                                   Placeholder="admin" />
                        </Border>

                        <Label Text="Contraseña" Style="{StaticResource FormLabel}" />
                        <Border Style="{StaticResource Field}">
                            <Entry x:Name="ContrasenaEntry"
                                   Style="{StaticResource FieldInput}"
                                   Placeholder="••••••••"
                                   IsPassword="True" />
                        </Border>

                        <Button x:Name="IniciarSesionButton"
                                Text="Iniciar sesión"
                                Style="{StaticResource PrimaryButton}"
                                Clicked="OnIniciarSesionClicked"
                                Margin="0,20,0,0" />

                    </VerticalStackLayout>
                </Border>

            </VerticalStackLayout>

        </Grid>
    </ScrollView>

</ContentPage>
