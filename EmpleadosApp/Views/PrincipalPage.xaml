<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="EmpleadosApp.Views.PrincipalPage"
             BackgroundColor="{StaticResource SurfaceBackground}"
             Title="Inicio">

    <Grid Padding="24">

        <VerticalStackLayout Spacing="20" VerticalOptions="Center">

            <Label Text="Bienvenido"
                   Style="{StaticResource HeaderLabel}"
                   HorizontalOptions="Center" />

            <Label Text="Selecciona una opcion"
                   Style="{StaticResource SubheaderLabel}"
                   HorizontalOptions="Center"
                   Margin="0,0,0,16" />

            <Border Style="{StaticResource Card}">
                <VerticalStackLayout Spacing="14">

                    <Button x:Name="VerEmpleadosButton"
                            Text="Ver empleados"
                            Style="{StaticResource PrimaryButton}" />

                    <Button x:Name="CerrarSesionButton"
                            Text="Cerrar sesion"
                            Style="{StaticResource DangerButton}" />

                </VerticalStackLayout>
            </Border>

        </VerticalStackLayout>

    </Grid>

</ContentPage>
