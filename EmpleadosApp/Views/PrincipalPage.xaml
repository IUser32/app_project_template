<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:EmpleadosApp.ViewModels"
             x:DataType="vm:DashboardViewModel"
             x:Class="EmpleadosApp.Views.PrincipalPage"
             BackgroundColor="{StaticResource SurfaceBackground}"
             Title="Inicio">

    <ScrollView>
        <VerticalStackLayout Padding="20,16,20,28" Spacing="18">

            <VerticalStackLayout Spacing="2">
                <Label Text="Panel de control"
                       Style="{StaticResource HeaderLabel}" />
                <Label Text="{Binding Saludo}"
                       Style="{StaticResource SubheaderLabel}" />
            </VerticalStackLayout>

            <!-- Tarjetas de estadistica -->
            <Grid ColumnDefinitions="*,*" ColumnSpacing="12">

                <Border Grid.Column="0" Style="{StaticResource Card}" Padding="18">
                    <VerticalStackLayout Spacing="2">
                        <Label Text="Empleados" Style="{StaticResource MetricLabel}" />
                        <Label Text="{Binding TotalEmpleados}" Style="{StaticResource MetricValue}" />
                        <Label Text="{Binding ResumenEmpleados}" Style="{StaticResource MetricHint}" />
                    </VerticalStackLayout>
                </Border>

                <Border Grid.Column="1" Style="{StaticResource Card}" Padding="18">
                    <VerticalStackLayout Spacing="2">
                        <Label Text="Activos" Style="{StaticResource MetricLabel}" />
                        <Label Text="{Binding EmpleadosActivos}"
                               Style="{StaticResource MetricValue}"
                               TextColor="{StaticResource Success}" />
                        <Label Text="{Binding EmpleadosInactivos, StringFormat='{0} inactivos'}"
                               Style="{StaticResource MetricHint}" />
                    </VerticalStackLayout>
                </Border>

            </Grid>

            <!-- Grafico: empleados por departamento -->
            <Label Text="EMPLEADOS POR DEPARTAMENTO" Style="{StaticResource SectionLabel}" />

            <Border Style="{StaticResource Card}">
                <VerticalStackLayout Spacing="16">

                    <VerticalStackLayout Spacing="14"
                                         IsVisible="{Binding HayEmpleados}"
                                         BindableLayout.ItemsSource="{Binding EmpleadosPorDepartamento}">
                        <BindableLayout.ItemTemplate>
                            <DataTemplate x:DataType="vm:BarraDepartamento">
                                <Grid ColumnDefinitions="96,*,Auto" ColumnSpacing="12">
                                    <Label Grid.Column="0"
                                           Text="{Binding Nombre}"
                                           FontSize="13"
                                           TextColor="{StaticResource Gray600}"
                                           LineBreakMode="TailTruncation"
                                           VerticalOptions="Center" />

                                    <Border Grid.Column="1"
                                            HeightRequest="12"
                                            BackgroundColor="{StaticResource Gray100}"
                                            StrokeThickness="0"
                                            VerticalOptions="Center">
                                        <Border.StrokeShape>
                                            <RoundRectangle CornerRadius="6" />
                                        </Border.StrokeShape>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="{Binding Peso, Converter={StaticResource Star}}" />
                                                <ColumnDefinition Width="{Binding PesoResto, Converter={StaticResource Star}}" />
                                            </Grid.ColumnDefinitions>
                                            <BoxView Grid.Column="0"
                                                     Color="{StaticResource Primary}"
                                                     CornerRadius="6" />
                                        </Grid>
                                    </Border>

                                    <Label Grid.Column="2"
                                           Text="{Binding Cantidad}"
                                           FontSize="14"
                                           FontAttributes="Bold"
                                           TextColor="{StaticResource Gray900}"
                                           VerticalOptions="Center"
                                           HorizontalOptions="End"
                                           WidthRequest="24" />
                                </Grid>
                            </DataTemplate>
                        </BindableLayout.ItemTemplate>
                    </VerticalStackLayout>

                    <Label Text="Aún no hay empleados registrados."
                           Style="{StaticResource RowSubtitle}"
                           HorizontalOptions="Center"
                           Padding="0,8"
                           IsVisible="{Binding HayEmpleados, Converter={StaticResource Invertir}}" />

                </VerticalStackLayout>
            </Border>

            <!-- Accesos / navegacion -->
            <Label Text="GESTIÓN" Style="{StaticResource SectionLabel}" />

            <Border Style="{StaticResource Card}" Padding="0">
                <VerticalStackLayout Spacing="0">

                    <Grid Padding="20,16" ColumnDefinitions="*,Auto,Auto" ColumnSpacing="10">
                        <Grid.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnEmpleadosTapped" />
                        </Grid.GestureRecognizers>
                        <Label Grid.Column="0" Text="Empleados" Style="{StaticResource RowTitle}" VerticalOptions="Center" />
                        <Label Grid.Column="1" Text="{Binding TotalEmpleados}" Style="{StaticResource RowValue}" VerticalOptions="Center" />
                        <Label Grid.Column="2" Style="{StaticResource Chevron}" />
                    </Grid>

                    <BoxView Style="{StaticResource Divider}" />

                    <Grid Padding="20,16" ColumnDefinitions="*,Auto,Auto" ColumnSpacing="10">
                        <Grid.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnDepartamentosTapped" />
                        </Grid.GestureRecognizers>
                        <Label Grid.Column="0" Text="Departamentos" Style="{StaticResource RowTitle}" VerticalOptions="Center" />
                        <Label Grid.Column="1" Text="{Binding TotalDepartamentos}" Style="{StaticResource RowValue}" VerticalOptions="Center" />
                        <Label Grid.Column="2" Style="{StaticResource Chevron}" />
                    </Grid>

                    <BoxView Style="{StaticResource Divider}" />

                    <Grid Padding="20,16" ColumnDefinitions="*,Auto,Auto" ColumnSpacing="10">
                        <Grid.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnCargosTapped" />
                        </Grid.GestureRecognizers>
                        <Label Grid.Column="0" Text="Cargos" Style="{StaticResource RowTitle}" VerticalOptions="Center" />
                        <Label Grid.Column="1" Text="{Binding TotalCargos}" Style="{StaticResource RowValue}" VerticalOptions="Center" />
                        <Label Grid.Column="2" Style="{StaticResource Chevron}" />
                    </Grid>

                    <BoxView Style="{StaticResource Divider}" />

                    <Grid Padding="20,16" ColumnDefinitions="*,Auto,Auto" ColumnSpacing="10">
                        <Grid.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnUsuariosTapped" />
                        </Grid.GestureRecognizers>
                        <Label Grid.Column="0" Text="Usuarios" Style="{StaticResource RowTitle}" VerticalOptions="Center" />
                        <Label Grid.Column="1" Text="{Binding TotalUsuarios}" Style="{StaticResource RowValue}" VerticalOptions="Center" />
                        <Label Grid.Column="2" Style="{StaticResource Chevron}" />
                    </Grid>

                </VerticalStackLayout>
            </Border>

            <Button Text="+ Nuevo empleado"
                    Style="{StaticResource PrimaryButton}"
                    Clicked="OnNuevoEmpleadoClicked" />

            <Button Text="Cerrar sesión"
                    Style="{StaticResource QuietButton}"
                    Clicked="OnCerrarSesionClicked" />

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
