<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:models="clr-namespace:EmpleadosApp.Models"
             x:Class="EmpleadosApp.Views.UsuariosListPage"
             BackgroundColor="{StaticResource SurfaceBackground}"
             Title="Usuarios">

    <Grid Padding="20,16,20,20" RowDefinitions="Auto,*,Auto" RowSpacing="14">

        <VerticalStackLayout Grid.Row="0" Spacing="2">
            <Label Text="Usuarios del sistema"
                   Style="{StaticResource HeaderLabel}" />
            <Label Text="Toca un usuario para editarlo"
                   Style="{StaticResource SubheaderLabel}" />
        </VerticalStackLayout>

        <Border Grid.Row="1" Style="{StaticResource Card}" Padding="0">
            <CollectionView x:Name="UsuariosCollection"
                            SelectionMode="Single"
                            SelectionChanged="OnUsuarioSeleccionado">
                <CollectionView.EmptyView>
                    <VerticalStackLayout Padding="24,48" Spacing="6" HorizontalOptions="Center" VerticalOptions="Center">
                        <Label Text="Sin usuarios"
                               FontSize="17"
                               FontAttributes="Bold"
                               TextColor="{StaticResource Gray900}"
                               HorizontalOptions="Center" />
                        <Label Text="Crea el primero con el botón de abajo."
                               Style="{StaticResource SubheaderLabel}"
                               HorizontalOptions="Center" />
                    </VerticalStackLayout>
                </CollectionView.EmptyView>
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="models:Usuario">
                        <VerticalStackLayout Spacing="0">
                            <Grid Padding="20,14" ColumnDefinitions="Auto,*,Auto,Auto" ColumnSpacing="14">

                                <Border Grid.Column="0"
                                        WidthRequest="44" HeightRequest="44"
                                        BackgroundColor="{StaticResource PrimaryLight}"
                                        VerticalOptions="Center">
                                    <Border.StrokeShape>
                                        <RoundRectangle CornerRadius="22" />
                                    </Border.StrokeShape>
                                    <Label Text="{Binding Username, Converter={StaticResource Inicial}}"
                                           TextColor="{StaticResource Primary}"
                                           FontSize="17"
                                           FontAttributes="Bold"
                                           HorizontalOptions="Center"
                                           VerticalOptions="Center" />
                                </Border>

                                <VerticalStackLayout Grid.Column="1" Spacing="2" VerticalOptions="Center">
                                    <Label Text="{Binding Username}" Style="{StaticResource RowTitle}" />
                                    <Label Text="{Binding NombreCompleto}" Style="{StaticResource RowSubtitle}" />
                                </VerticalStackLayout>

                                <Border Grid.Column="2" Style="{StaticResource Pill}">
                                    <Label Text="{Binding Estado}" Style="{StaticResource PillText}" />
                                </Border>

                                <Label Grid.Column="3" Style="{StaticResource Chevron}" />
                            </Grid>
                            <BoxView Style="{StaticResource Divider}" />
                        </VerticalStackLayout>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </Border>

        <Button Grid.Row="2"
                Text="+ Nuevo usuario"
                Style="{StaticResource PrimaryButton}"
                Clicked="OnNuevoUsuarioClicked" />

    </Grid>

</ContentPage>
